reg2ascii proc
    push ax
    push bx
    push cx
    push dx

    mov ah, 0
    mov cx, 3
    mov si, 0
    mov di, bx
    mov dx, 0

conv_loop:
    mov dl, dataDiv[si]
    div dl
    add al, '0'
    mov [di], al
    inc di
    mov al, ah
    mov ah, 0
    inc si
    loop conv_loop

    mov byte ptr [di], '$'   ; terminador DOS

    pop dx
    pop cx
    pop bx
    pop ax
    ret
reg2ascii endp
