;ingfresar una oracion 
;mosrtrarrla en efecto espejo 
; ej gola alog 
.8086
.model small
.stack 100h

.data
   cartel db "Ingrese una oracion..." ,0dh,0ah
          db "Para luego mostrarla en efecto espejo..." ,0dh,0ah,'$'

.code
    main proc
        mov ax , @data
        mov ds, ax 
        

        mov ah , 09h
        mov dx , offset cartel
        int 21h
    jmp fin_programa
     

    fin_programa:
        mov ax ,4c00h
        int 21h

    main endp
end    